p00 = ( !p00 ∨ A0 ) ∧ ( !p00 ∨ B0 ) ∧ ( !A0 ∨ !B0 ∨ p00 )
p01 = ( !p01 ∨ A0 ) ∧ ( !p01 ∨ B1 ) ∧ ( !A0 ∨ !B1 ∨ p01 )
p02 = ( !p02 ∨ A0 ) ∧ ( !p02 ∨ B2 ) ∧ ( !A0 ∨ !B2 ∨ p02 )

p10 = ( !p10 ∨ A1 ) ∧ ( !p10 ∨ B0 ) ∧ ( !A1 ∨ !B0 ∨ p10 )
p11 = ( !p11 ∨ A1 ) ∧ ( !p11 ∨ B1 ) ∧ ( !A1 ∨ !B1 ∨ p11 )
p12 = ( !p12 ∨ A1 ) ∧ ( !p12 ∨ B2 ) ∧ ( !A1 ∨ !B2 ∨ p12 )

p20 = ( !p20 ∨ A2 ) ∧ ( !p20 ∨ B0 ) ∧ ( !A2 ∨ !B0 ∨ p20 )
p21 = ( !p21 ∨ A2 ) ∧ ( !p21 ∨ B1 ) ∧ ( !A2 ∨ !B1 ∨ p21 )
p22 = ( !p22 ∨ A2 ) ∧ ( !p22 ∨ B2 ) ∧ ( !A2 ∨ !B2 ∨ p22 )

P0  = ( !P0 ∨ p00 ) ∧ ( !p00 ∨ P0 )

P1  = ( !p01 ∨ !p10 ∨ !P1 ) ∧ ( p01 ∨ p10 ∨ !P1 ) ∧ ( p01 ∨ !p10 ∨ P1 ) ∧ ( !p01 ∨ p10 ∨ P1 )
C1  = ( !C1 ∨ p01 ) ∧ ( !C1 ∨ p10 ) ∧ ( !p01 ∨ !p10 ∨ C1 )

/* Column 2 (inputs: p02, p11, p20, C1) implemented by cascading 2-input XOR/ANDs:
   s21 = p02 XOR p11
   t21 = p02 AND p11
   s22 = s21 XOR p20
   t22 = s21 AND p20
   s23 = s22 XOR C1
   t23 = s22 AND C1
   P2  = s23
   C2  = t21 OR t22 OR t23
*/
s21  = ( !p02 ∨ !p11 ∨ !s21 ) ∧ ( p02 ∨ p11 ∨ !s21 ) ∧ ( p02 ∨ !p11 ∨ s21 ) ∧ ( !p02 ∨ p11 ∨ s21 )
t21  = ( !t21 ∨ p02 ) ∧ ( !t21 ∨ p11 ) ∧ ( !p02 ∨ !p11 ∨ t21 )

s22  = ( !s21 ∨ !p20 ∨ !s22 ) ∧ ( s21 ∨ p20 ∨ !s22 ) ∧ ( s21 ∨ !p20 ∨ s22 ) ∧ ( !s21 ∨ p20 ∨ s22 )
t22  = ( !t22 ∨ s21 ) ∧ ( !t22 ∨ p20 ) ∧ ( !s21 ∨ !p20 ∨ t22 )

s23  = ( !s22 ∨ !C1 ∨ !s23 ) ∧ ( s22 ∨ C1 ∨ !s23 ) ∧ ( s22 ∨ !C1 ∨ s23 ) ∧ ( !s22 ∨ C1 ∨ s23 )
t23  = ( !t23 ∨ s22 ) ∧ ( !t23 ∨ C1 ) ∧ ( !s22 ∨ !C1 ∨ t23 )

P2  = ( !P2 ∨ s23 ) ∧ ( !s23 ∨ P2 )

C2  = ( !C2 ∨ t21 ∨ t22 ∨ t23 ) ∧ ( !t21 ∨ C2 ) ∧ ( !t22 ∨ C2 ) ∧ ( !t23 ∨ C2 )

/* Column 3 (inputs: p12, p21, C2):
   s31 = p12 XOR p21
   t31 = p12 AND p21
   s32 = s31 XOR C2
   t32 = s31 AND C2
   P3  = s32
   C3  = t31 OR t32
*/
s31  = ( !p12 ∨ !p21 ∨ !s31 ) ∧ ( p12 ∨ p21 ∨ !s31 ) ∧ ( p12 ∨ !p21 ∨ s31 ) ∧ ( !p12 ∨ p21 ∨ s31 )
t31  = ( !t31 ∨ p12 ) ∧ ( !t31 ∨ p21 ) ∧ ( !p12 ∨ !p21 ∨ t31 )

s32  = ( !s31 ∨ !C2 ∨ !s32 ) ∧ ( s31 ∨ C2 ∨ !s32 ) ∧ ( s31 ∨ !C2 ∨ s32 ) ∧ ( !s31 ∨ C2 ∨ s32 )
t32  = ( !t32 ∨ s31 ) ∧ ( !t32 ∨ C2 ) ∧ ( !s31 ∨ !C2 ∨ t32 )

P3  = ( !P3 ∨ s32 ) ∧ ( !s32 ∨ P3 )

C3  = ( !C3 ∨ t31 ∨ t32 ) ∧ ( !t31 ∨ C3 ) ∧ ( !t32 ∨ C3 )

/* Column 4 (inputs: p22, C3):
   P4 = p22 XOR C3
   C4 = p22 AND C3
*/
P4  = ( !p22 ∨ !C3 ∨ !P4 ) ∧ ( p22 ∨ C3 ∨ !P4 ) ∧ ( p22 ∨ !C3 ∨ P4 ) ∧ ( !p22 ∨ C3 ∨ P4 )
C4  = ( !C4 ∨ p22 ) ∧ ( !C4 ∨ C3 ) ∧ ( !p22 ∨ !C3 ∨ C4 )

P5  = ( !P5 ∨ C4 ) ∧ ( !C4 ∨ P5 )